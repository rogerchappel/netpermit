{
  "name": "netpermit",
  "version": "0.1.0",
  "description": "Local-first preflight policy checker for outbound network intent.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "netpermit": "./src/cli.js"
  },
  "files": [
    "src",
    "examples",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-check.js",
    "test": "node --test",
    "check": "npm run build && npm test",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run package:smoke",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "network",
    "policy",
    "cli",
    "security",
    "preflight",
    "agents"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/netpermit.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/netpermit/issues"
  },
  "homepage": "https://github.com/rogerchappel/netpermit#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  }
}
